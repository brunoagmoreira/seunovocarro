# Porta do servidor (padrão: 3001)
PORT=3001

# Swagger OpenAPI em /api/docs — em produção fica desligado salvo com true
# SWAGGER_ENABLED=true

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/seunovocarro?schema=public"

# JWT Secret — TROCAR por uma string segura em produção!
JWT_SECRET="trocar-por-uma-chave-secreta-forte"
JWT_EXPIRES_IN="7d"

# Opcional: segunda camada para GET/PATCH /vehicles/admin/* (integração server-to-server).
# Se definido, toda requisição admin de veículos deve enviar o header X-SNC-Admin-Vehicle-Key com o mesmo valor.
# Gere com: openssl rand -hex 32
# ADMIN_VEHICLE_DATA_SECRET=""

# Cloudflare R2 (Storage de imagens)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="seunovocarro-media"
R2_PUBLIC_URL=""
