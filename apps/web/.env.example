# URL base da API Nest (com sufixo /api)
NEXT_PUBLIC_API_URL=https://api.seunovocarro.com.br/api

# Opcional: Client ID OAuth Web do Google (mesmo valor configurável no Admin → Configurações).
# Útil se GET /site-settings/public falhar no browser; o backend ainda precisa do mesmo ID na base.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Se o front chama /api no mesmo host do Next (Easypanel), o servidor repassa para a API:
# API_INTERNAL_URL=http://seunovocarro-api:3001
# SERVER_API_PROXY_URL=https://api.seunovocarro.com.br
